# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=60

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
